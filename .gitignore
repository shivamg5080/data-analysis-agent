.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or binary, you shouldn't ignore these files, but for a specific
#   project, it can be useful.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if you choose to ignore it, remove the "/" in front of the following line.
# /Pipfile.lock

# poetry
#   Similar to Pipenv, see https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-to-version-control
# poetry.lock

# pdm
#   Similar to Pipenv, see https://pdm.fming.dev/#use-pdm-in-a-project
.pdm.toml
.pdm-python
.pdm-build/

# PEP 582; used by e.g. github.com/frenzy/venveler
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath libraries
*.sage.py

